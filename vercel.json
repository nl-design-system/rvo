{
  "buildCommand": "pnpm run build && pnpm --filter @nl-rvo/design-system-website generate",
  "outputDirectory": "packages/design-system-website/dist",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "build": {
    "env": {
      "DOCUSAURUS_BASE_URL": "/docs/"
    }
  },
  "headers": [
    {
      "source": "/docs/assets/fonts/:file+",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
